# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://vigil:vigil123@localhost:3306/vigildb

# ─── Gemini (Google AI) ───────────────────────────────────────────────────────
# Obtenha sua chave gratuita em: aistudio.google.com/app/apikey
API_KEY_AI=seu-gemini-api-key-aqui

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
VIGIL_API_KEY=vigil-internal-api-key-2026

# ─── SMTP Email (Gmail recomendado) ───────────────────────────────────────────
# Passo a passo Gmail:
#   1. Acesse myaccount.google.com → Segurança → Verificação em duas etapas (ative)
#   2. Em "Senhas de app", gere uma senha para "Vigil Summit"
#   3. Use essa senha abaixo (sem espaços)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=seu_email@gmail.com
EMAIL_FROM_NAME=Vigil Summit

# ─── Twilio WhatsApp Sandbox (gratuito para testes) ───────────────────────────
# Passo a passo:
#   1. Acesse console.twilio.com → Messaging → Try it out → WhatsApp Sandbox
#   2. Copie Account SID e Auth Token da tela principal
#   3. O participante precisa enviar "join <código>" para +14155238886 (WhatsApp) uma vez
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=vigil-admin-secret-change-in-production
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASSWORD=vigil2026

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
